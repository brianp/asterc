# Test the Seedfile evaluation pipeline.
#
# Tests the wrapping logic and verifies the generated wrapper
# produces correct output. All functions are inlined here because
# cross-module function calls do not yet produce values at runtime.
# ── Inlined from eval.aster ──────────────────────────────────────────
def seedfile_class_source() -> String
  let src = "class Seedfile includes DynamicReceiver\n"

  src = src + "    pub name: String\n"
  src = src + "    pub version_str: String\n"
  src = src + "    pub compiler_version: String\n"
  src = src + "    pub quarantine_days: Int\n"
  src = src + "    pub dep_serial: String\n"
  src = src + "    pub task_serial: String\n"
  src = src + "    pub override_serial: String\n"
  src = src + "\n"
  src = src + "    pub def package(pkg_name: String, version: String = \"0.0.0\") -> Void\n"
  src = src + "        name = pkg_name\n"
  src = src + "        version_str = version\n"
  src = src + "\n"
  src = src + "    pub def compiler(ver: String) -> Void\n"
  src = src + "        compiler_version = ver\n"
  src = src + "\n"
  src = src + "    pub def quarantine(days: Int) -> Void\n"
  src = src + "        quarantine_days = days\n"
  src = src + "\n"
  src = src + "    pub def task(task_name: String, cmd: String) -> Void\n"
  src = src + "        task_serial = task_serial + \"TASK:\" + task_name + \"|\" + cmd + \"\\n\"\n"
  src = src + "\n"
  src = src + "    pub def override(dep_name: String, version: String = \"\", path: String = \"\", git: String = \"\", branch: String = \"\") -> Void\n"
  src = src + "        override_serial = override_serial + \"OVERRIDE:\" + dep_name + \"|\" + version + \"|\" + path + \"|\" + git + \"|\" + branch + \"\\n\"\n"
  src = src + "\n"
  src = src + "    pub def method_missing(fn_name: String, args: Map[String, String]) -> Void\n"
  src = src + "        let dep_name = args[\"name\"].or(default: fn_name)\n"
  src = src + "        let dep_version = args[\"version\"].or(default: \"*\")\n"
  src = src + "        let dep_path = args[\"path\"].or(default: \"\")\n"
  src = src + "        let dep_git = args[\"git\"].or(default: \"\")\n"
  src = src + "        let dep_dev = args[\"dev\"].or(default: \"false\")\n"
  src = src + "        let dep_trusted = args[\"trusted\"].or(default: \"false\")\n"
  src = src + "        dep_serial = dep_serial + \"DEP:\" + dep_name + \"|\" + dep_version + \"|\" + dep_path + \"|\" + dep_git + \"|\" + dep_dev + \"|\" + dep_trusted + \"\\n\"\n"

  src


def seedfile_constructor() -> String
  "let _seed = Seedfile(name: \"\", version_str: \"\", compiler_version: \"\", quarantine_days: 0, dep_serial: \"\", task_serial: \"\", override_serial: \"\")\n"


def seedfile_footer() -> String
  let foot = "say(message: \"NAME:\" + _seed.name)\n"

  foot = foot + "say(message: \"VERSION:\" + _seed.version_str)\n"
  foot = foot + "say(message: \"COMPILER:\" + _seed.compiler_version)\n"
  foot = foot + "say(message: \"QUARANTINE:\" + to_string(value: _seed.quarantine_days))\n"
  foot = foot + "say(message: _seed.dep_serial)\n"
  foot = foot + "say(message: _seed.task_serial)\n"
  foot = foot + "say(message: _seed.override_serial)\n"

  foot


def transform_line(line: String) -> String
  let trimmed = line.trim()

  if trimmed.len() == 0
    return ""

  if trimmed.starts_with(pre: "#")
    return trimmed

  if trimmed.contains(str: "(")
    return "_seed." + trimmed

  trimmed


def wrap_seedfile(content: String) -> String
  let result = seedfile_class_source() + "\n"

  result = result + "def main() -> Int\n"
  result = result + "    " + seedfile_constructor()

  let lines = content.split(sep: "\n")

  for line in lines
    let transformed = transform_line(line: line)

    if transformed.len() > 0
      result = result + "    " + transformed + "\n"

  result = result + "    " + seedfile_footer().replace(old: "\n", new: "\n    ")
  result = result + "0\n"

  result


# ── Test helpers ─────────────────────────────────────────────────────
def assert_eq(actual: String, expected: String, label: String)
  if actual != expected
    say(message: "FAIL [{label}]: expected '{expected}', got '{actual}'")


def assert_contains(haystack: String, needle: String, label: String)
  if haystack.contains(str: needle) == false
    say(message: "FAIL [{label}]: output does not contain '{needle}'")


# ── Tests ────────────────────────────────────────────────────────────
# Test transform_line: empty lines
# Test transform_line: comment lines
# Test transform_line: whitespace-only lines
# Test transform_line: bare function call
# Test transform_line: indented function call
# Test transform_line: function call with named args
# Test that seedfile_class_source contains key elements
# Test that seedfile_constructor creates the instance
# Test that seedfile_footer prints all fields
# Test full wrapping of a sample Seedfile
# The wrapped output should contain the class definition
# The wrapped output should contain def main
# The wrapped output should contain the transformed calls
# The wrapped output should contain the serialization footer
# The comment should pass through
def main() -> Int
  let fail_count = 0
  let empty = transform_line(line: "")

  assert_eq(actual: empty, expected: "", label: "empty line")

  let comment = transform_line(line: "# this is a comment")

  assert_eq(actual: comment, expected: "# this is a comment", label: "comment line")

  let whitespace = transform_line(line: "   ")

  assert_eq(actual: whitespace, expected: "", label: "whitespace line")

  let call = transform_line(line: "package(pkg_name: \"my-app\", version: \"0.1.0\")")

  assert_eq(actual: call, expected: "_seed.package(pkg_name: \"my-app\", version: \"0.1.0\")", label: "bare call")

  let indented = transform_line(line: "  http(version: \"1.2.0\")")

  assert_eq(actual: indented, expected: "_seed.http(version: \"1.2.0\")", label: "indented call")

  let named = transform_line(line: "quarantine(days: 3)")

  assert_eq(actual: named, expected: "_seed.quarantine(days: 3)", label: "call with named args")

  let cls = seedfile_class_source()

  assert_contains(haystack: cls, needle: "class Seedfile includes DynamicReceiver", label: "class header")
  assert_contains(haystack: cls, needle: "pub def package", label: "package method")
  assert_contains(haystack: cls, needle: "pub def method_missing", label: "method_missing")
  assert_contains(haystack: cls, needle: "dep_serial", label: "dep_serial field")

  let ctor = seedfile_constructor()

  assert_contains(haystack: ctor, needle: "let _seed = Seedfile(", label: "constructor")
  assert_contains(haystack: ctor, needle: "dep_serial", label: "dep_serial init")

  let foot = seedfile_footer()

  assert_contains(haystack: foot, needle: "NAME:", label: "footer NAME")
  assert_contains(haystack: foot, needle: "VERSION:", label: "footer VERSION")
  assert_contains(haystack: foot, needle: "QUARANTINE:", label: "footer QUARANTINE")
  assert_contains(haystack: foot, needle: "dep_serial", label: "footer dep_serial")

  let sample = "# My app\npackage(pkg_name: \"my-app\", version: \"0.1.0\")\ncompiler(ver: \"0.1.0\")\n\nhttp(version: \"1.2.0\")\njson(version: \"0.4.0\")\n\ntask(task_name: \"test\", cmd: \"aster test\")\n"
  let wrapped = wrap_seedfile(content: sample)

  assert_contains(haystack: wrapped, needle: "class Seedfile includes DynamicReceiver", label: "wrapped class")
  assert_contains(haystack: wrapped, needle: "def main() -> Int", label: "wrapped main")
  assert_contains(haystack: wrapped, needle: "_seed.package(", label: "wrapped package call")
  assert_contains(haystack: wrapped, needle: "_seed.http(", label: "wrapped http call")
  assert_contains(haystack: wrapped, needle: "_seed.json(", label: "wrapped json call")
  assert_contains(haystack: wrapped, needle: "_seed.task(", label: "wrapped task call")
  assert_contains(haystack: wrapped, needle: "_seed.name", label: "wrapped serialization")
  assert_contains(haystack: wrapped, needle: "# My app", label: "wrapped comment")
  say(message: "All eval tests passed.")

  0
